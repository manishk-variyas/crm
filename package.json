{
  "name": "crm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:remotes": "pnpm --filter './apps/!(*shell)' --parallel run dev",
    "dev:shell": "pnpm --filter @crm/shell run dev",
    "serve": "pnpm --filter './apps/*' --parallel run serve",
    "serve:remotes": "pnpm --filter './apps/!(*shell)' --parallel run serve",
    "build": "pnpm -r run build",
    "build:packages": "pnpm --filter \"./packages/**\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "push": "bash scripts/push-to-vm.sh"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
